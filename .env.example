# ─── MongoDB Atlas ────────────────────────────────────────────────────────────
# Get this from Atlas → Connect → Drivers
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_URL= 
MONGODB_DB_NAME=

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=  
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=43200

# ─── Media (stored locally) ───────────────────────────────────────────────────
MEDIA_DIR=media

# ─── OpenAI (optional — AI classification) ───────────────────────────────────
# Leave blank to disable AI classification (manual category selection only)
OPENAI_API_KEY=

# ─── App ──────────────────────────────────────────────────────────────────────
APP_NAME=CivicPulse
DEBUG=true
